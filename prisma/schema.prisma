generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  RESCHEDULE_REQUESTED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CartStatus {
  ACTIVE
  ORDERED
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  name                String
  phone               String?
  whatsapp            String?
  preferredContact    String               @default("WhatsApp")
  role                Role                 @default(CUSTOMER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  pets                Pet[]
  appointments        Appointment[]
  favoriteProducts    FavoriteProduct[]
  favoriteServices    FavoriteService[]
  carts               Cart[]
  orders              Order[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Pet {
  id           String        @id @default(cuid())
  userId       String
  name         String
  species      String
  breed        String?
  birthDate    DateTime?
  ageLabel     String?
  sex          String?
  weightKg     Decimal?      @db.Decimal(6, 2)
  photoUrl     String?
  notes        String?
  allergies    String?
  conditions   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([userId])
}

model Service {
  id           String               @id @default(cuid())
  slug         String               @unique
  name         String
  description  String
  active       Boolean              @default(true)
  price        Decimal?             @db.Decimal(10, 2)
  durationMin  Int?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  appointments AppointmentService[]
  favorites    FavoriteService[]
}

model Appointment {
  id             String               @id @default(cuid())
  requestCode    String               @unique
  requestGroupId String?
  userId         String
  petId          String
  requestedAt    DateTime
  notes          String?
  status         AppointmentStatus    @default(PENDING)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  user           User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  pet            Pet                  @relation(fields: [petId], references: [id], onDelete: Restrict)
  services       AppointmentService[]
  slot           AppointmentSlot?

  @@index([userId, requestedAt])
  @@index([petId])
  @@index([requestGroupId])
}

model AppointmentService {
  appointmentId String
  serviceId     String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@id([appointmentId, serviceId])
}

model AppointmentSlot {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  startsAt      DateTime
  resourceKey   String      @default("default")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([startsAt, resourceKey])
}

model AvailabilityBlock {
  id          String   @id @default(cuid())
  startsAt    DateTime
  endsAt      DateTime
  resourceKey String   @default("default")
  reason      String?
  createdAt   DateTime @default(now())

  @@index([startsAt, endsAt, resourceKey])
}

model Product {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  description      String
  category         String
  sku              String            @unique
  price            Decimal?          @db.Decimal(10, 2)
  promotionalPrice Decimal?          @db.Decimal(10, 2)
  stock            Int               @default(0)
  active           Boolean           @default(true)
  images           String[]
  information      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  variants         ProductVariant[]
  favorites        FavoriteProduct[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  name       String
  sku        String      @unique
  price      Decimal?    @db.Decimal(10, 2)
  stock      Int         @default(0)
  active     Boolean     @default(true)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
}

model FavoriteProduct {
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
}

model FavoriteService {
  userId    String
  serviceId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([userId, serviceId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  order     Order?

  @@index([userId, status])
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

model Order {
  id        String      @id @default(cuid())
  orderCode String      @unique
  userId    String
  cartId    String?     @unique
  status    OrderStatus @default(PENDING)
  subtotal  Decimal     @db.Decimal(12, 2)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  cart      Cart?       @relation(fields: [cartId], references: [id], onDelete: SetNull)
  items     OrderItem[]

  @@index([userId, createdAt])
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String
  sku       String
  unitPrice Decimal         @db.Decimal(10, 2)
  quantity  Int
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([orderId])
}
